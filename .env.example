# Copy to `.env` and edit. Every value is OPTIONAL — the server boots without it.
# All variables use the CAKE_ prefix (see src/mcp_template/settings.py).

# Bakery Cloud API key (single-tenant / local convenience). For multi-user HTTP,
# prefer the per-request `X-Cake-Api-Key` header or the `authenticate` tool.
# CAKE_API_KEY=cake_demo123

# Tool surface: essentials (default, small) or extended (full).
# CAKE_MODE=essentials

# Transport + bind address for network transports.
# CAKE_TRANSPORT=stdio        # stdio | http | sse
# CAKE_HOST=127.0.0.1
# CAKE_PORT=3011

# Logging level for server-side logs (written to stderr).
# CAKE_LOG_LEVEL=INFO

# Header name used to read a per-request API key over HTTP.
# CAKE_API_KEY_HEADER=X-Cake-Api-Key

# Domain knob for the cake demo.
# CAKE_OVEN_MAX_TEMP_C=250
