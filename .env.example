# Copy to `.env` and edit. Every value is OPTIONAL — the server boots without it.
# Server settings use the PRS_MCP_ prefix (see src/just_prs_mcp/settings.py).

# Tool surface: essentials (default, small) or extended (full — batch, bulk
# downloads, HuggingFace upload, reference-panel / pgen scoring).
# PRS_MCP_MODE=essentials

# Cache directory for catalog metadata, scoring files, and reference panels.
# Leave unset to use just-prs's own default (PRS_CACHE_DIR / platformdirs).
# PRS_MCP_CACHE_DIR=/path/to/cache

# Default genome build and reference panel for tools that don't specify one.
# PRS_MCP_DEFAULT_GENOME_BUILD=GRCh38
# PRS_MCP_DEFAULT_PANEL=1000g

# DuckDB memory limit for batch PRS computation (e.g. "8GB").
# PRS_MCP_DUCKDB_MEMORY_LIMIT=8GB

# HuggingFace token for the push_catalog_to_hf tool (extended mode). The native
# HF_TOKEN env var is also honored.
# PRS_MCP_HF_TOKEN=hf_...

# Transport + bind address for network transports.
# PRS_MCP_TRANSPORT=stdio        # stdio | http | sse
# PRS_MCP_HOST=127.0.0.1
# PRS_MCP_PORT=3011

# Logging level for server-side logs (written to stderr).
# PRS_MCP_LOG_LEVEL=INFO
